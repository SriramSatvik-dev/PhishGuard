{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "2.0",
  "description": "Real-time phishing URL detection powered by ML",

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "PhishGuard"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "webNavigation",
    "windows"
],

  "host_permissions": [
    "http://localhost:8000/*",
    "http://*/*",
    "https://*/*"
  ]
}